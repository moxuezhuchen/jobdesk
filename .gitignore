# Python caches and build outputs
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
build/
dist/
.build*/
# mypy's emitted cache (the inner .gitignore covers file contents; this rule
# keeps the directory itself out of `git status`).
.mypy_cache/

# Sdist unpack artifact produced by `python -m build`. The directory name
# follows PEP 621 versioning (e.g. jobdesk-0.5.0/), so the wildcard matches
# any version-specific unpack without re-editing this file per release.
jobdesk-*/

# Test and tool caches
.pytest_cache/
.pytest_tmp*/
/.pytest_*/
/.debug_delete/
.pytest_*.log
.superpowers/
.coverage
htmlcov/

# Local runtime data
tmp_pytest*/
fake_project/
fake_project_real/
# tmp60f7j8ix/ holds pytest smoke artifacts from real-g16 / chk / TS tests;
# it is never part of the repo and should not be accidentally staged.
tmp60f7j8ix/
# tmpXXXXXXX/ directories created by manual shell commands in cwd
/tmp*/
# Gau-*.inp spill from g16 WSL scratch (g16 sometimes writes to cwd when
# GAUSS_SCRDIR is misconfigured or the scratch dir is missing)
Gau-*.inp

# Release-readiness review scratch logs (ruff_review.log, mypy_review.log,
# pytest_review*.log, .public_tree.log, etc.)
*.review.log
.review_*.log
.ruff_*.log
.pytest_review*.log
.mypy_review.log
.public_tree.log
*_review.log

# Local one-off scripts/logs from manual validation
m8_real_backend.py
m8_max_parallel.py

# Editor and OS noise
.idea/
.vscode/
.antigravitycli/
Thumbs.db
Desktop.ini

# mypy stub path (see ``mypy.ini`` ``mypy_path = stubs``). These are
# either pip-installed stub packages or hand-written shadow stubs for
# third-party libraries (currently rdkit); they are not authored source
# and are re-generated by ``pip install -e ".[chem,dev]"`` / the local
# ``scripts/install_stubs.sh`` workflow.
stubs/

# Local workflow templates accidentally written to cwd during
# dev/test cycles of the nodegraph editor.
workflow.yaml
